{
  "output_dir": "./optimized_rlt_output",
  "seed": 42,
  "teacher": {
    "model": "claude-3-5-sonnet-20241022",
    "temperature": 0.7,
    "max_tokens": 1024,
    "budget_limit": 50.0,
    "cache_size": 10000,
    "cache_ttl_hours": 168,
    "comment": "Claude Sonnet 4 as teacher via API"
  },
  "student": {
    "model_name": "meta-llama/Llama-3.2-3B-Instruct",
    "use_4bit": true,
    "use_8bit": false,
    "compute_dtype": "bfloat16",
    "use_flash_attention": true,
    "use_peft": true,
    "peft_method": "adalora",
    "lora_r": 32,
    "lora_alpha": 64,
    "adalora_init_r": 12,
    "adalora_target_r": 32,
    "gradient_checkpointing": true,
    "mixed_precision": "bf16",
    "comment": "Optimized HuggingFace student with all improvements"
  },
  "evaluation": {
    "model_name": "meta-llama/Llama-3.2-3B-Instruct",
    "batch_size": 8
  },
  "training": {
    "learning_rate": 2e-5,
    "batch_size": 1,
    "gradient_accumulation_steps": 8,
    "num_epochs": 3,
    "group_size": 4,
    "eval_frequency": 1,
    "kl_weight": 0.1,
    "correctness_weight": 0.5,
    "confidence_weight": 0.3,
    "length_penalty_weight": 0.1
  },
  "data": {
    "dataset": "gsm8k",
    "max_train_samples": 1000,
    "max_eval_samples": 100,
    "max_length": 1024,
    "cache_dir": "./data_cache"
  },
  "supported_student_models": [
    "meta-llama/Llama-3.2-3B-Instruct",
    "meta-llama/Llama-3.2-11B-Instruct",
    "mistralai/Mistral-7B-Instruct-v0.3",
    "mistralai/Mistral-Small-Instruct-2409"
  ]
}